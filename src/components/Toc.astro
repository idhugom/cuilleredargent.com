---
import type { Block } from '../lib/data';
interface Props { blocks: Block[]; }
const { blocks } = Astro.props;
function slugify(s: string): string {
  return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-').slice(0, 60);
}
const items = blocks
  .filter((b): b is Extract<Block, { type: 'heading' }> => b.type === 'heading' && b.level === 2)
  .map((b) => ({ id: b.id || slugify(b.text), text: b.text }));
---
{items.length >= 2 && (
  <nav class="toc" aria-label="Sommaire">
    <p class="toc__title">Au sommaire</p>
    <ol>
      {items.map((it, i) => (
        <li><a href={`#${it.id}`} data-toc-link><span class="toc__i">{String(i + 1).padStart(2, '0')}</span>{it.text}</a></li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc { font-size: var(--step--1); }
  .toc__title {
    font-family: var(--font-sans); font-size: var(--step--2); letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 1rem; font-weight: 600;
  }
  .toc ol { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .toc a {
    display: grid; grid-template-columns: 2rem 1fr; gap: 0.5rem; align-items: baseline;
    padding: 0.45rem 0; color: var(--muted); line-height: 1.3;
    border-left: 2px solid transparent; padding-left: 0.9rem; margin-left: -0.9rem;
    transition: color 0.3s, border-color 0.3s;
  }
  .toc a:hover, .toc a.is-active { color: var(--ink); border-color: var(--accent); }
  .toc__i { font-family: var(--font-display); font-style: italic; color: var(--accent); font-size: 0.85em; }
</style>

<script>
  // Surligne l'entrée active du sommaire selon le scroll.
  function initToc() {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
    if (!links.length) return;
    const map = new Map<string, HTMLAnchorElement>();
    links.forEach((l) => { const id = l.getAttribute('href')!.slice(1); map.set(id, l); });
    const heads = links.map((l) => document.getElementById(l.getAttribute('href')!.slice(1))).filter(Boolean) as HTMLElement[];
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          links.forEach((l) => l.classList.remove('is-active'));
          map.get(e.target.id)?.classList.add('is-active');
        }
      });
    }, { rootMargin: '-10% 0px -70% 0px' });
    heads.forEach((h) => io.observe(h));
  }
  document.addEventListener('astro:page-load', initToc);
</script>
