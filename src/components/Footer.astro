---
const year = new Date().getFullYear();
---
<footer class="ft">
  <div class="container-wide">
    <div class="ft__top">
      <div class="ft__brand">
        <p class="eyebrow eyebrow--accent">Le magazine</p>
        <a href="/" class="ft__word chrome-text">Cuillère d'argent</a>
        <p class="ft__tag">Le magazine qui déniche, décortique et raconte — de la maison à la tech, de l'auto au grand voyage.</p>
      </div>
      <nav class="ft__cols" aria-label="Pied de page">
        <div>
          <h3>Explorer</h3>
          <a href="/articles" class="link-ul">Tous les articles</a>
          <a href="/recherche" class="link-ul">Rechercher</a>
          <a href="/rss.xml" class="link-ul">Flux RSS</a>
        </div>
        <div>
          <h3>La maison</h3>
          <a href="/a-propos" class="link-ul">À propos</a>
          <a href="/mentions-legales" class="link-ul">Mentions légales</a>
          <a href="/sitemap.xml" class="link-ul">Plan du site</a>
        </div>
      </nav>
    </div>
    <div class="ft__bottom">
      <p>© {year} Cuillère d'argent. Tous droits réservés.</p>
      <p class="ft__made">Fabriqué à la main — sans WordPress.</p>
    </div>
  </div>
</footer>

<style>
  .ft {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(3rem, 6vw, 6rem) 0 2rem;
    margin-top: clamp(4rem, 8vw, 8rem);
    position: relative;
  }
  .ft::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: var(--chrome); opacity: 0.5;
  }
  .ft__top {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(2rem, 5vw, 5rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .ft__word {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 4.4rem);
    line-height: 0.95; letter-spacing: -0.03em; font-weight: 480;
    margin: 0.4rem 0 1rem;
  }
  .ft__tag { max-width: 42ch; color: var(--silver-2); }
  .ft__cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .ft__cols h3 {
    font-family: var(--font-sans); font-size: var(--step--2); letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--silver-3); margin-bottom: 1rem; font-weight: 600;
  }
  .ft__cols a { display: block; margin-bottom: 0.6rem; color: var(--silver-1); }
  .ft__bottom {
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    padding-top: 1.6rem; font-size: var(--step--2); color: var(--silver-3);
  }
  @media (max-width: 720px) {
    .ft__top { grid-template-columns: 1fr; }
  }
</style>
