---
import Base from '../layouts/Base.astro';
import Mercury from '../components/Mercury.astro';
import Cover from '../components/Cover.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getAllArticles, topTags, formatDate, CATALOG_TOTAL } from '../lib/data';

const articles = getAllArticles();
const featured = articles[0];
const secondary = articles.slice(1, 3);
const grid = articles.slice(3, 9);
const ticker = articles.slice(0, 10);
const rest = articles.slice(9, 17);
const tags = topTags(9);
const published = articles.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: "Cuillère d'argent",
  url: 'https://www.cuilleredargent.com/',
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://www.cuilleredargent.com/recherche?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---
<Base
  title="Cuillère d'argent — Le magazine qui déniche, décortique et raconte"
  description="Magazine généraliste indépendant. Guides, enquêtes et décryptages de la maison à la tech, de l'auto au grand voyage. Un contenu soigné, sans bruit."
  canonical="/"
  jsonLd={jsonLd}
  bodyClass="page-home"
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero__inner container-wide">
      <div class="hero__lead">
        <p class="eyebrow" data-reveal>Magazine généraliste · indépendant</p>
        <h1 class="hero__title">
          <span class="l" data-reveal style="--reveal-delay:60ms">On déniche,</span>
          <span class="l" data-reveal style="--reveal-delay:150ms">on décortique,</span>
          <span class="l i" data-reveal style="--reveal-delay:240ms">on raconte.</span>
        </h1>
        <p class="hero__dek" data-reveal style="--reveal-delay:340ms">
          De la cuisine connectée au sommet du Kilimandjaro : des guides et décryptages
          pensés pour comprendre, choisir et s'émerveiller — un sujet à la fois.
        </p>
        <div class="hero__actions" data-reveal style="--reveal-delay:420ms">
          <a href="/articles" class="btn btn--accent">Explorer le magazine</a>
          <a href="/recherche" class="btn">Rechercher un sujet</a>
        </div>
        <dl class="hero__stats" data-reveal style="--reveal-delay:500ms">
          <div><dt>{CATALOG_TOTAL}</dt><dd>sujets au catalogue</dd></div>
          <div><dt>100%</dt><dd>contenu original</dd></div>
          <div><dt>0</dt><dd>WordPress</dd></div>
        </dl>
      </div>

      <div class="hero__stage" aria-hidden={featured ? undefined : 'true'}>
        <Mercury class="hero__merc" />
        {featured && (
          <a href={featured.url} class="hero__feature" data-hover>
            <span class="hero__badge">La une</span>
            <Cover image={featured.image} alt={featured.title} sizes="(max-width: 900px) 90vw, 420px" ratio="3 / 4" loading="eager" fetchpriority="high" class="hero__featimg" />
            <span class="hero__featmeta">
              <span class="hero__feattag">{featured.tags[0] || 'À la une'}</span>
              <span class="hero__feattitle">{featured.title}</span>
            </span>
          </a>
        )}
      </div>
    </div>
  </section>

  {ticker.length > 3 && (
    <div class="ticker" aria-hidden="true">
      <div class="ticker__track">
        {[0, 1].map(() => (
          <span class="ticker__group">
            {ticker.map((t) => (<><span class="ticker__item">{t.title}</span><span class="ticker__sep">✦</span></>))}
          </span>
        ))}
      </div>
    </div>
  )}

  <!-- ============ À LA UNE ============ -->
  {secondary.length > 0 && (
    <section class="feature container-wide">
      <div class="sec-head" data-reveal>
        <p class="eyebrow eyebrow--accent">À la une</p>
        <h2>Les histoires du moment</h2>
      </div>
      <div class="feature__grid">
        {secondary.map((a, i) => <ArticleCard article={a} variant="feature" index={i} />)}
      </div>
    </section>
  )}

  <!-- ============ GRILLE ============ -->
  {grid.length > 0 && (
    <section class="grid-sec container-wide">
      <div class="grid-sec__grid">
        {grid.map((a, i) => <ArticleCard article={a} index={i} />)}
      </div>
    </section>
  )}

  <!-- ============ RUBRIQUES ============ -->
  {tags.length > 3 && (
    <section class="topics container-wide" data-reveal>
      <div class="topics__head">
        <p class="eyebrow eyebrow--accent">Explorer</p>
        <h2>Par rubrique</h2>
      </div>
      <div class="topics__cloud">
        {tags.map((t) => (
          <a href={`/recherche?q=${encodeURIComponent(t.tag)}`} class="topics__chip" data-hover>
            {t.tag}<span>{t.count}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ============ SUITE ============ -->
  {rest.length > 0 && (
    <section class="more container-wide">
      <div class="sec-head" data-reveal>
        <p class="eyebrow eyebrow--accent">Le fil</p>
        <h2>À explorer aussi</h2>
      </div>
      <div class="more__list">
        {rest.map((a, i) => <ArticleCard article={a} variant="text" index={i} />)}
      </div>
      <div class="more__cta" data-reveal>
        <a href="/articles" class="btn">Tout le magazine →</a>
      </div>
    </section>
  )}

  {articles.length === 0 && (
    <section class="container" style="padding:4rem 0;text-align:center">
      <p class="eyebrow eyebrow--accent">Bientôt</p>
      <h2 style="font-size:var(--step-3);margin-top:1rem">Les articles arrivent</h2>
      <p style="color:var(--muted);margin-top:1rem">Le contenu éditorial est en cours de fabrication.</p>
    </section>
  )}
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero { padding-top: clamp(2rem, 5vw, 4.5rem); overflow: hidden; }
  .hero__inner { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .hero__title { font-size: var(--step-7); line-height: 0.92; letter-spacing: -0.035em; margin: 1.4rem 0; }
  .hero__title .l { display: block; }
  .hero__title .i { font-style: italic; color: var(--muted); }
  .hero__dek { max-width: 46ch; font-size: var(--step-1); color: var(--ink-soft); line-height: 1.5; }
  .hero__actions { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }
  .hero__stats { display: flex; gap: clamp(1.5rem, 4vw, 3rem); margin-top: 2.6rem; }
  .hero__stats dt { font-family: var(--font-display); font-size: var(--step-3); line-height: 1; }
  .hero__stats dd { font-size: var(--step--2); color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.3rem; }

  .hero__stage { position: relative; display: grid; place-items: center; min-height: 34rem; }
  .hero__merc { position: absolute; inset: -8% -6%; width: 116%; opacity: 0.9; z-index: 0; filter: saturate(1.05); }
  .hero__feature {
    position: relative; z-index: 2; width: min(78%, 22rem); display: block;
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 50px 90px -40px rgba(11,11,14,0.6);
    transform: rotate(-3deg); transition: transform 0.7s var(--ease);
    background: var(--ink);
  }
  .hero__feature:hover { transform: rotate(-1deg) translateY(-6px); }
  .hero__badge {
    position: absolute; top: 1rem; left: 1rem; z-index: 4;
    background: var(--accent); color: #fff; font-size: var(--step--2); font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; padding: 0.35rem 0.8rem; border-radius: 100px;
  }
  .hero__featimg { width: 100%; }
  .hero__featmeta { position: absolute; inset: auto 0 0 0; z-index: 4; padding: 3.5rem 1.3rem 1.3rem; background: linear-gradient(transparent, rgba(11,11,14,0.9)); color: var(--paper); display: block; }
  .hero__feattag { display: block; font-size: var(--step--2); letter-spacing: 0.16em; text-transform: uppercase; color: var(--silver-2); margin-bottom: 0.4rem; }
  .hero__feattitle { font-family: var(--font-display); font-size: var(--step-1); line-height: 1.1; }

  /* ---------- TICKER ---------- */
  .ticker { margin-top: clamp(3rem, 6vw, 5rem); border-block: 1px solid var(--line); padding: 1rem 0; overflow: hidden; white-space: nowrap; }
  .ticker__track { display: inline-flex; animation: marquee 46s linear infinite; }
  .ticker__group { display: inline-flex; align-items: center; }
  .ticker__item { font-family: var(--font-display); font-size: var(--step-1); font-style: italic; padding: 0 1.2rem; color: var(--ink-soft); }
  .ticker__sep { color: var(--accent); }
  @keyframes marquee { to { transform: translateX(-50%); } }
  .ticker:hover .ticker__track { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) { .ticker__track { animation: none; } }

  /* ---------- SECTIONS ---------- */
  .sec-head { margin: clamp(3.5rem, 7vw, 6rem) 0 2rem; }
  .sec-head h2, .topics__head h2 { font-size: var(--step-4); margin-top: 0.5rem; letter-spacing: -0.02em; }

  .feature__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.6rem, 4vw, 3rem); }
  .grid-sec { margin-top: clamp(2.5rem, 5vw, 4rem); }
  .grid-sec__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.6rem, 3vw, 2.6rem); }

  .topics { margin-top: clamp(3.5rem, 7vw, 6rem); }
  .topics__head { margin-bottom: 1.8rem; }
  .topics__cloud { display: flex; flex-wrap: wrap; gap: 0.8rem; }
  .topics__chip {
    display: inline-flex; align-items: center; gap: 0.6rem;
    border: 1px solid var(--line-strong); border-radius: 100px; padding: 0.6rem 1.1rem;
    font-size: var(--step--1); font-weight: 500; transition: background 0.35s var(--ease), color 0.35s, border-color 0.35s, transform 0.35s;
    text-transform: capitalize;
  }
  .topics__chip span { color: var(--muted); font-size: var(--step--2); }
  .topics__chip:hover { background: var(--ink); color: var(--paper); border-color: var(--ink); transform: translateY(-2px); }
  .topics__chip:hover span { color: var(--silver-3); }

  .more__list { display: grid; grid-template-columns: 1fr 1fr; gap: 0 clamp(2rem, 5vw, 4rem); }
  .more__cta { margin-top: 3rem; text-align: center; }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__stage { min-height: 26rem; order: -1; }
    .feature__grid, .grid-sec__grid, .more__list { grid-template-columns: 1fr; }
  }
</style>
